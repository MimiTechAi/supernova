# ── Liquid Swarm — Environment Configuration ─────────────────────────
#
# Copy this to .env and fill in your values.
# At minimum, set ONE provider's API key.

# ── Provider Selection ───────────────────────────────────────────────
# Supported: nvidia, openai, anthropic, ollama
# Default: auto-detects from available API keys
LLM_PROVIDER=nvidia

# ── API Keys (set the one matching your provider) ────────────────────
NVIDIA_API_KEY=your-nvidia-nim-api-key
# LLM_API_KEY=sk-your-openai-key       # for OpenAI
# LLM_API_KEY=sk-ant-your-key          # for Anthropic

# ── Optional Overrides ──────────────────────────────────────────────
# LLM_MODEL=gpt-4o-mini                # Override default model
# LLM_BASE_URL=https://my-proxy.com/v1 # Custom endpoint (proxies, vLLM)

# ── Cost Control ────────────────────────────────────────────────────
# COST_BUDGET_PER_RUN=0.10             # Max USD per swarm run (optional)

# ── Authentication ──────────────────────────────────────────────────
# SWARM_API_KEYS=key1,key2,key3        # Comma-separated, protects /api/*
#                                       # Leave unset for open dev access
